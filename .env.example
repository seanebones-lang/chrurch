# xAI (Grok) — church site chat at /api/chat
XAI_API_KEY=
# Optional override (default: grok-3-mini)
# XAI_CHAT_MODEL=grok-3-mini

# Text-to-speech (POST /api/chat/tts) — default voice Ara
# XAI_TTS_VOICE=ara
# XAI_TTS_LANGUAGE=en

# Optional: canonical site URL for metadata + chat source links (see app/layout.tsx)
# NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: Formspree for /api/contact
# FORMSPREE_FORM_ID=

# --- Chat rate limits (requests per IP per minute) ---
# CHAT_RATE_LIMIT_PER_MINUTE=45
# CHAT_TTS_RATE_LIMIT_PER_MINUTE=30
# CHAT_PDF_RATE_LIMIT_PER_MINUTE=25

# --- Optional vector RAG (sermon semantic search) ---
# Upstash Vector index (dimension 1536 for OpenAI text-embedding-3-small)
# UPSTASH_VECTOR_REST_URL=
# UPSTASH_VECTOR_REST_TOKEN=
# OPENAI_API_KEY=
# CHAT_VECTOR_TOP_K=5

# POST /api/chat/ingest — Bearer secret to re-index sermons into Upstash
# CHAT_INGEST_SECRET=

# Sanity (see next-sanity / studio)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# --- Railway PostgreSQL (set on Vercel when the app uses a server DB) ---
# Railway: create a Postgres plugin, copy DATABASE_URL from Variables.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
